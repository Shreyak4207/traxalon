{
  "rewrites": [
    {
      "source": "/t/:token",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-src 'self' https://www.google.com https://maps.google.com https://maps.googleapis.com;"
        }
      ]
    }
  ]
}
